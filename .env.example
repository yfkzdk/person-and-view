# ========================================
# API密钥配置文件
# ========================================

# 选择LLM提供商（二选一）
LLM_PROVIDER=deepseek

# DeepSeek API配置（推荐，性价比高）
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-chat

# Anthropic Claude API配置（备选）
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# LLM_MODEL=claude-3-5-sonnet-20241022

# ========================================
# TTS语音配置
# ========================================
TTS_LANGUAGE=zh-CN
TTS_VOICE=zh-CN-XiaoxiaoNeural
TTS_RATE=0.9
TTS_PITCH=1.0

# ========================================
# 服务器配置
# ========================================
HOST=0.0.0.0
PORT=8000

# ========================================
# VAD语音检测配置
# ========================================
VAD_SAMPLE_RATE=16000
VAD_THRESHOLD=0.5

# ========================================
# LLM配置
# ========================================
LLM_MAX_TOKENS=2000
LLM_TEMPERATURE=0.7

# ========================================
# Redis配置（可选，用于分布式部署）
# ========================================
REDIS_URL=redis://localhost:6379
USE_REDIS=false

# ========================================
# 数据库配置
# ========================================
# SQLite (开发/单机): sqlite:///data/voices.db
# PostgreSQL (生产/多用户): postgresql://user:pass@host/dbname
DATABASE_URL=sqlite:///data/voices.db

# ========================================
# 获取API密钥指南
# ========================================
# DeepSeek: https://platform.deepseek.com/
#   1. 注册账号
#   2. 创建API密钥
#   3. 复制密钥到上面的 DEEPSEEK_API_KEY
#
# Anthropic: https://console.anthropic.com/
#   1. 注册账号
#   2. 创建API密钥
#   3. 复制密钥到上面的 ANTHROPIC_API_KEY