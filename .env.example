# ========================================
# API密钥配置文件
# ========================================

# 选择LLM提供商（二选一）
LLM_PROVIDER=deepseek

# DeepSeek API配置（推荐，性价比高）
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-chat

# Anthropic Claude API配置（备选）
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# LLM_MODEL=claude-sonnet-4-6

# ========================================
# TTS语音配置
# ========================================

# Provider: edge_tts_ssml (默认，SSML增强，免费云) / edge_tts (纯文本) / openai (最自然，需API key) / cosyvoice (零样本克隆)
TTS_PROVIDER=edge_tts_ssml

# Edge TTS 配置
TTS_LANGUAGE=zh-CN
TTS_VOICE=YunyangNeural   # 男声: YunyangNeural YunxiNeural / 女声: XiaoxiaoNeural YunjianNeural

# OpenAI TTS 配置（TTS_PROVIDER=openai 时需要）
# OPENAI_API_KEY=sk-your_openai_api_key_here
# OPENAI_TTS_MODEL=tts-1   # tts-1 (快) / tts-1-hd (高质) / gpt-4o-mini-tts (最自然)
# OPENAI_TTS_VOICE=nova    # alloy echo fable onyx nova shimmer

# 火山引擎 TTS 配置（TTS_PROVIDER=volcengine 时需，国内免翻，免费 10万字符/月）
# VOLCENGINE_APP_ID=你的appid
# VOLCENGINE_ACCESS_TOKEN=你的access_token
# VOLCENGINE_TTS_VOICE=zh_male_chat   # 音色: zh_male_chat / zh_female_gentle / zh_female_natural 等

# ========================================
# 服务器配置
# ========================================
HOST=0.0.0.0
PORT=8000

# ========================================
# VAD语音检测配置
# ========================================
VAD_SAMPLE_RATE=16000
VAD_THRESHOLD=0.5

# ========================================
# LLM配置
# ========================================
LLM_MAX_TOKENS=2000
LLM_TEMPERATURE=0.7

# ========================================
# Redis配置（可选，用于分布式部署）
# ========================================
REDIS_URL=redis://localhost:6379
USE_REDIS=false

# ========================================
# 数据库配置
# ========================================
# SQLite (开发/单机): sqlite:///data/voices.db
# PostgreSQL (生产/多用户): postgresql://user:pass@host/dbname
DATABASE_URL=sqlite:///data/voices.db

# ========================================
# 获取API密钥指南
# ========================================
# DeepSeek: https://platform.deepseek.com/
#   1. 注册账号
#   2. 创建API密钥
#   3. 复制密钥到上面的 DEEPSEEK_API_KEY
#
# Anthropic: https://console.anthropic.com/
#   1. 注册账号
#   2. 创建API密钥
#   3. 复制密钥到上面的 ANTHROPIC_API_KEY
#
# OpenAI (TTS): https://platform.openai.com/
#   1. 注册账号
#   2. 创建API密钥
#   3. 复制密钥到上面的 OPENAI_API_KEY
